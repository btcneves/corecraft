# ─────────────────────────────────────────────────────────────────────────────
# CoreCraft — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────────────────
# Copie este ficheiro para .env antes de iniciar:
#   cp .env.example .env
#
# Os valores abaixo funcionam diretamente com a stack Docker sem alterações.
# Em produção, use credenciais fortes e nunca cometa o .env no git.
# ─────────────────────────────────────────────────────────────────────────────

# Credenciais RPC do Bitcoin Core
# Usadas pelos backends FastAPI para comunicar com o nó via JSON-RPC.
BTC_RPC_USER=user
BTC_RPC_PASSWORD=password

# rpcauth: formato gerado por share/rpcauth/rpcauth.py do Bitcoin Core.
# Deve corresponder ao utilizador e palavra-passe acima.
# Apenas necessário quando o bitcoind é iniciado via Docker Compose —
# o bitcoin-init container usa este valor para configurar o nó.
BTC_RPC_AUTH=user:corecraft$55eef9f3661634839386ead63a2e72d60d0ef27470547ec7b4b12d0e9dce8db2

# Nível de detalhe dos logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Perfil padrão do Docker Compose.
# Mantém `docker compose up` iniciando a stack completa.
COMPOSE_PROFILES=all

# Token opcional para Cloudflare Tunnel nomeado.
# Necessário apenas ao usar docker-compose.cloudflare.yml ou o target
# vps-cloudflare no workflow de deploy.
# CLOUDFLARE_TUNNEL_TOKEN=
